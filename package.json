{
  "name": "votewise-india",
  "version": "2.0.0",
  "description": "AI-powered Indian election education assistant using 9 Google Cloud services: Gemini AI, Cloud Translation, Text-to-Speech, Vision API, Natural Language, BigQuery, Firebase Auth, Firestore, and Analytics",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NODE_ENV=test jest --coverage --forceExit",
    "test:e2e": "npx playwright test",
    "test:all": "npm test && npm run test:e2e"
  },
  "engines": { "node": "24.x" },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "firebase-admin": "^12.2.0",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0",
    "@playwright/test": "^1.44.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 10000,
    "testPathIgnorePatterns": ["/node_modules/", "/e2e/"]
  }
}
